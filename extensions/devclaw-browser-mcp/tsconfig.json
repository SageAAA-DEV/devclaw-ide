{
	"compilerOptions": {
		"module": "commonjs",
		"target": "ES2022",
		"lib": ["ES2022"],
		"outDir": "dist",
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"declaration": true,
		"sourceMap": true,
		"paths": {
			"vscode": ["../../src/vscode-dts/vscode.d.ts"]
		}
	},
	"include": ["src/**/*.ts"]
}
